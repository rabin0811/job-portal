@model IEnumerable<JobPortal.Models.Job>
@{
    ViewData["Title"] = "Employer Dashboard";
    var companyName = Context.Session.GetString("UserName");
}

<div class="row">
    <div class="col-lg-9">
        <div class="card mb-4 border-0 shadow-sm bg-white p-4">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h4 class="fw-bold mb-0">Employer Dashboard</h4>
                    <p class="text-muted small mb-0">Manage your job postings and applicants</p>
                </div>
                <a asp-controller="Job" asp-action="Create" class="btn btn-primary rounded-pill px-4 fw-bold">
                    <i class="bi bi-plus-lg me-1"></i> Post a Job
                </a>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="card p-3 border-0 shadow-sm text-center">
                    <div class="fs-2 fw-bold text-primary">@Model.Count()</div>
                    <div class="text-muted small">Total Jobs</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card p-3 border-0 shadow-sm text-center">
                    <div class="fs-2 fw-bold text-success">@Model.Where(j => j.IsActive).Count()</div>
                    <div class="text-muted small">Active Listings</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card p-3 border-0 shadow-sm text-center">
                    <div class="fs-2 fw-bold text-warning">@Model.Sum(j => j.Applications.Count)</div>
                    <div class="text-muted small">Total Applicants</div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0 fw-bold">Your Job Listings</h5>
            </div>
            @if (!Model.Any())
            {
                <div class="card-body text-center py-5">
                    <i class="bi bi-briefcase fs-1 text-muted mb-3 d-block"></i>
                    <h6>No jobs posted yet</h6>
                    <p class="text-muted small">Start attracting candidates by posting your first job.</p>
                    <a asp-controller="Job" asp-action="Create" class="btn btn-primary rounded-pill px-5 fw-bold">Post a Job</a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">Job Title</th>
                                <th>Type</th>
                                <th>Posted</th>
                                <th class="text-center">Applicants</th>
                                <th class="text-end pe-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var job in Model)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="fw-bold">@job.Title</div>
                                        <div class="text-muted small">@job.Location</div>
                                    </td>
                                    <td>
                                        <span class="badge rounded-pill text-bg-light border">@job.JobType</span>
                                    </td>
                                    <td class="text-muted small">@job.IssueDate.ToShortDateString()</td>
                                    <td class="text-center">
                                        <a asp-controller="Application" asp-action="JobApplications" asp-route-jobId="@job.Id"
                                           class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                            @job.Applications.Count <i class="bi bi-people ms-1"></i>
                                        </a>
                                    </td>
                                    <td class="text-end pe-4">
                                        <a asp-controller="Job" asp-action="Edit" asp-route-id="@job.Id" class="btn btn-sm btn-outline-secondary rounded-pill px-3 me-1">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form asp-controller="Job" asp-action="Delete" asp-route-id="@job.Id" method="post" class="d-inline"
                                              onsubmit="return confirm('Delete this job?')">
                                            <button class="btn btn-sm btn-outline-danger rounded-pill px-3">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <div class="col-lg-3">
        <div class="card border-0 shadow-sm p-4 text-center">
            <i class="bi bi-building fs-1 text-primary mb-2"></i>
            <h6 class="fw-bold mb-0">Your Company</h6>
            <p class="text-muted small mt-1 mb-3">Manage your employer profile</p>
            <a asp-action="Index" class="btn btn-outline-primary btn-sm rounded-pill w-100 fw-bold">View Company</a>
        </div>
    </div>
</div>
