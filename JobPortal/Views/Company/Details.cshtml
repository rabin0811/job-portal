@model JobPortal.Models.Company
@{
    ViewData["Title"] = Model.Name;
}

<div class="row">
    <div class="col-lg-8">
        <div class="card mb-4 overflow-hidden border-0 shadow-sm">
            <div style="height:120px;background:linear-gradient(135deg,#004182 0%,#0a66c2 100%);"></div>
            <div class="card-body px-4 pt-0">
                <div class="d-flex align-items-end mt-n4 mb-3">
                    <div class="bg-white border shadow-sm d-flex align-items-center justify-content-center me-3" style="width:80px;height:80px;min-width:80px;">
                        @if (!string.IsNullOrEmpty(Model.LogoPath))
                        { <img src="@Model.LogoPath" style="width:76px;height:76px;object-fit:cover;"> }
                        else
                        { <i class="bi bi-building fs-1 text-secondary"></i> }
                    </div>
                    <div class="pb-1">
                        <h4 class="fw-bold mb-0">@Model.Name</h4>
                        <div class="text-muted small">@Model.Location</div>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.Website))
                {
                    <a href="@Model.Website" target="_blank" class="btn btn-outline-primary btn-sm rounded-pill px-3 fw-bold me-2">
                        <i class="bi bi-globe me-1"></i> Website
                    </a>
                }
                <button class="btn btn-primary btn-sm rounded-pill px-4 fw-bold">Follow</button>
            </div>
        </div>

        <div class="card mb-4 border-0 shadow-sm p-4">
            <h5 class="fw-bold mb-3">About</h5>
            <p class="text-muted">@(string.IsNullOrEmpty(Model.Description) ? "No description provided." : Model.Description)</p>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0 fw-bold">Open Positions (@Model.Jobs.Count)</h5>
            </div>
            <div class="list-group list-group-flush">
                @foreach (var job in Model.Jobs.Where(j => j.IsActive))
                {
                    <a asp-controller="Job" asp-action="Details" asp-route-id="@job.Id"
                       class="list-group-item list-group-item-action p-4">
                        <div class="fw-bold text-primary">@job.Title</div>
                        <div class="text-muted small">@job.Location • @job.JobType</div>
                        <div class="text-muted small mt-1">Posted @job.IssueDate.ToShortDateString()</div>
                    </a>
                }
                @if (!Model.Jobs.Any(j => j.IsActive))
                {
                    <div class="p-4 text-center text-muted small">No open positions right now.</div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card border-0 shadow-sm p-4">
            <h6 class="fw-bold mb-3">Company Overview</h6>
            <div class="mb-2 small"><i class="bi bi-geo-alt me-2 text-muted"></i>@(Model.Location ?? "–")</div>
            <div class="mb-2 small"><i class="bi bi-briefcase me-2 text-muted"></i>@Model.Jobs.Count open jobs</div>
            @if (!string.IsNullOrEmpty(Model.Website))
            {
                <div class="mb-2 small"><i class="bi bi-globe me-2 text-muted"></i><a href="@Model.Website" target="_blank" class="text-decoration-none">@Model.Website</a></div>
            }
        </div>
    </div>
</div>
