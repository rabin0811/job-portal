@model IEnumerable<JobPortal.Models.Job>
@{
    ViewData["Title"] = "Home";
}

<div class="row">
    <!-- Left Sidebar -->
    <div class="col-lg-3 mb-4">
        <div class="card overflow-hidden">
            <div class="bg-linkedin-pattern py-4 text-center border-bottom" style="background-color: #a0b4b7; height: 60px;"></div>
            <div class="card-body text-center mt-n4">
                <div class="bg-white rounded-circle d-inline-block p-1 mt-n5 border shadow-sm">
                    <i class="bi bi-person-circle fs-1 text-muted px-2"></i>
                </div>
                <h5 class="card-title fw-bold mt-2 mb-0">Welcome!</h5>
                <p class="text-muted small">Stay up to date with your professional world</p>
                @if (Context.Session.GetString("UserId") == null)
                {
                    <hr />
                    <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary btn-sm rounded-pill w-100 mb-2">Sign In</a>
                }
            </div>
        </div>
        
        <div class="card mt-3">
            <div class="card-body p-3">
                <h6 class="fw-bold mb-3 small">Recent Searches</h6>
                <div class="d-flex align-items-center mb-2 small text-muted">
                    <i class="bi bi-search me-2"></i> Software Engineer
                </div>
                <div class="d-flex align-items-center small text-muted">
                    <i class="bi bi-search me-2"></i> Remote Jobs
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="col-lg-6 mb-4">
        <div class="card mb-3 p-3 text-center hero-card border-0 bg-white">
            <h2 class="display-6 fw-light mb-3">Welcome to your <span class="text-primary fw-bold">professional community</span></h2>
            <div class="search-bar mt-2 d-flex">
                <input class="form-control border-0 bg-transparent" placeholder="Search for jobs, skills, or companies...">
                <button class="btn btn-primary px-4 rounded">Search</button>
            </div>
        </div>

        <h5 class="fw-bold mb-3">New Jobs for You</h5>
        
        @foreach (var job in Model)
        {
            <div class="card mb-3 job-card">
                <div class="card-body p-3">
                    <div class="d-flex">
                        <div class="company-logo me-3">
                             <div class="bg-light d-flex align-items-center justify-content-center border" style="width: 56px; height: 56px;">
                                <i class="bi bi-building fs-3 text-secondary"></i>
                            </div>
                        </div>
                        <div class="flex-grow-1">
                            <h6 class="mb-0 fw-bold">
                                <a asp-controller="Job" asp-action="Details" asp-route-id="@job.Id" class="text-decoration-none text-primary">@job.Title</a>
                            </h6>
                            <div class="small">@job.Company?.Name</div>
                            <div class="text-muted small">@job.Location • @job.JobType</div>
                            
                            <div class="mt-2 text-success small fw-bold">
                               <i class="bi bi-lightning-charge-fill"></i> Actively hiring
                            </div>
                            
                            <div class="text-muted extra-small mt-1" style="font-size: 11px;">
                                Posted @((DateTime.Now - job.IssueDate).Days) days ago
                            </div>
                        </div>
                        <div>
                             <button class="btn btn-sm btn-outline-primary rounded-circle"><i class="bi bi-bookmark"></i></button>
                        </div>
                    </div>
                </div>
            </div>
        }
        
        <div class="text-center mt-3">
            <a asp-controller="Job" asp-action="Index" class="text-decoration-none fw-bold">See more jobs <i class="bi bi-arrow-right"></i></a>
        </div>
    </div>

    <!-- Right Sidebar -->
    <div class="col-lg-3">
        <div class="card">
            <div class="card-body">
                <h6 class="fw-bold mb-3 d-flex justify-content-between align-items-center">
                    News Feed
                    <i class="bi bi-info-square-fill text-muted small" style="font-size: 10px;"></i>
                </h6>
                <div class="mb-3">
                    <div class="fw-bold small mb-1">• Tech Hiring on the Peak</div>
                    <div class="text-muted smaller" style="font-size: 11px;">2d ago • 12,043 readers</div>
                </div>
                <div class="mb-3">
                    <div class="fw-bold small mb-1">• Remote Work vs Hybrid</div>
                    <div class="text-muted smaller" style="font-size: 11px;">1d ago • 8,421 readers</div>
                </div>
                 <div class="mb-0">
                    <div class="fw-bold small mb-1">• Global Salary Trends 2026</div>
                    <div class="text-muted smaller" style="font-size: 11px;">5h ago • 3,112 readers</div>
                </div>
                <hr />
                <div class="text-center small">
                    <a href="#" class="text-decoration-none text-muted fw-bold">Show more <i class="bi bi-chevron-down"></i></a>
                </div>
            </div>
        </div>
    </div>
</div>
