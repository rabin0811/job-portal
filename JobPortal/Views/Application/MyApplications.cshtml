@model IEnumerable<JobPortal.Models.Application>
@{
    ViewData["Title"] = "My Applications";
}

<div class="row">
    <div class="col-lg-9">
        <div class="card mb-4 border-0 shadow-sm p-4">
            <h4 class="fw-bold mb-0">My Applications</h4>
            <p class="text-muted small">Track the status of your job applications</p>
        </div>

        @if (!Model.Any())
        {
            <div class="card border-0 shadow-sm p-5 text-center">
                <i class="bi bi-file-earmark-text fs-1 text-muted mb-3 d-block"></i>
                <h5 class="fw-bold">No applications yet</h5>
                <p class="text-muted small">Start applying for jobs to track your progress here.</p>
                <a asp-controller="Job" asp-action="Index" class="btn btn-primary rounded-pill px-5 fw-bold">Browse Jobs</a>
            </div>
        }
        else
        {
            @foreach (var app in Model)
            {
                var badgeClass = app.Status switch {
                    JobPortal.Models.ApplicationStatus.Accepted  => "text-bg-success",
                    JobPortal.Models.ApplicationStatus.Rejected  => "text-bg-danger",
                    JobPortal.Models.ApplicationStatus.Reviewed  => "text-bg-info",
                    _ => "text-bg-secondary"
                };
                <div class="card border-0 shadow-sm mb-3 p-4">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h6 class="fw-bold mb-0 text-primary">@app.Job?.Title</h6>
                            <div class="text-muted small">@app.Job?.Company?.Name • @app.Job?.Location</div>
                            <div class="text-muted small mt-1">Applied @app.ApplicationDate.ToShortDateString()</div>
                            @if (!string.IsNullOrEmpty(app.Message))
                            {
                                <div class="small text-muted mt-2 fst-italic">"@app.Message"</div>
                            }
                        </div>
                        <span class="badge rounded-pill @badgeClass px-3 py-2">@app.Status</span>
                    </div>
                </div>
            }
        }
    </div>

    <div class="col-lg-3">
        <div class="card border-0 shadow-sm p-4">
            <h6 class="fw-bold mb-3">Application Stats</h6>
            <div class="d-flex justify-content-between mb-2 small">
                <span>Total Applied</span>
                <span class="fw-bold">@Model.Count()</span>
            </div>
            <div class="d-flex justify-content-between mb-2 small text-success">
                <span>Accepted</span>
                <span class="fw-bold">@Model.Count(a => a.Status == JobPortal.Models.ApplicationStatus.Accepted)</span>
            </div>
            <div class="d-flex justify-content-between mb-2 small text-danger">
                <span>Rejected</span>
                <span class="fw-bold">@Model.Count(a => a.Status == JobPortal.Models.ApplicationStatus.Rejected)</span>
            </div>
            <div class="d-flex justify-content-between small text-muted">
                <span>Pending</span>
                <span class="fw-bold">@Model.Count(a => a.Status == JobPortal.Models.ApplicationStatus.Pending)</span>
            </div>
        </div>
    </div>
</div>
