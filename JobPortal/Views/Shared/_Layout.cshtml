<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Elevate Workforce Solutions</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="sticky-top">
        <nav class="navbar navbar-expand-lg navbar-dark bg-linkedin py-1 shadow-sm">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center" asp-controller="Home" asp-action="Index">
                   <i class="bi bi-briefcase-fill me-2 fs-3 text-white"></i>
                   <span class="fw-bold tracking-tight">Elevate Workforce Solutions</span>
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-lg-4">
                        <li class="nav-item">
                            <a class="nav-link d-flex flex-column align-items-center py-2 px-3 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door-fill fs-5"></i>
                                <span class="nav-text small">Home</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link d-flex flex-column align-items-center py-2 px-3 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Job" ? "active" : "")" asp-controller="Job" asp-action="Index">
                                <i class="bi bi-briefcase-fill fs-5"></i>
                                <span class="nav-text small">Jobs</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link d-flex flex-column align-items-center py-2 px-3 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Company" ? "active" : "")" asp-controller="Company" asp-action="Index">
                                <i class="bi bi-building fs-5"></i>
                                <span class="nav-text small">Companies</span>
                            </a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle d-flex flex-column align-items-center py-2 px-3" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-grid-fill fs-5"></i>
                                <span class="nav-text small">Categories</span>
                            </a>
                            <ul class="dropdown-menu shadow border-0 mt-2">
                                <li><a class="dropdown-item" asp-controller="Job" asp-action="Index" asp-route-type="Full-time">Full-time</a></li>
                                <li><a class="dropdown-item" asp-controller="Job" asp-action="Index" asp-route-type="Part-time">Part-time</a></li>
                                <li><a class="dropdown-item" asp-controller="Job" asp-action="Index" asp-route-type="Contract">Contract</a></li>
                                <li><a class="dropdown-item" asp-controller="Job" asp-action="Index" asp-route-type="Remote">Remote</a></li>
                                <li><a class="dropdown-item" asp-controller="Job" asp-action="Index" asp-route-type="Internship">Internship</a></li>
                            </ul>
                        </li>
                    </ul>
                    
                    <div class="d-flex align-items-center">
                        @if (Context.Session.GetInt32("UserId") == null)
                        {
                            <a class="btn btn-outline-light btn-sm rounded-pill px-4 me-2" asp-controller="Account" asp-action="Login">Sign in</a>
                            <a class="btn btn-primary btn-sm rounded-pill px-4 border-white" asp-controller="Account" asp-action="Register">Join now</a>
                        }
                        else
                        {
                            <ul class="navbar-nav">
                                @if (Context.Session.GetString("UserRole") == "Admin")
                                {
                                    <li class="nav-item me-3">
                                        <a class="nav-link d-flex flex-column align-items-center py-2" asp-controller="Admin" asp-action="Dashboard">
                                            <i class="bi bi-shield-lock-fill fs-5"></i>
                                            <span class="nav-text small">Admin</span>
                                        </a>
                                    </li>
                                }
                                @if (Context.Session.GetString("UserRole") == "Employer")
                                {
                                    <li class="nav-item me-3">
                                        <a class="nav-link d-flex flex-column align-items-center py-2" asp-controller="Company" asp-action="Dashboard">
                                            <i class="bi bi-speedometer2 fs-5"></i>
                                            <span class="nav-text small">Employer Dashboard</span>
                                        </a>
                                    </li>
                                }
                                @if (Context.Session.GetString("UserRole") == "JobSeeker")
                                {
                                     <li class="nav-item me-3">
                                        <a class="nav-link d-flex flex-column align-items-center py-2" asp-controller="Application" asp-action="MyApplications">
                                            <i class="bi bi-file-earmark-check fs-5"></i>
                                            <span class="nav-text small">My Apps</span>
                                        </a>
                                    </li>
                                }
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle d-flex flex-column align-items-center py-1" href="#" role="button" data-bs-toggle="dropdown">
                                        <i class="bi bi-person-circle fs-4"></i>
                                        <span class="nav-text small">Me <i class="bi bi-caret-down-fill" style="font-size: 8px;"></i></span>
                                    </a>
                                    <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2">
                                        <li class="px-3 py-2">
                                            <div class="fw-bold">@Context.Session.GetString("UserName")</div>
                                            <div class="text-muted small">@Context.Session.GetString("UserEmail")</div>
                                        </li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item" asp-controller="Account" asp-action="Logout">Sign Out</a></li>
                                    </ul>
                                </li>
                            </ul>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="pb-5 pt-4">
        <div class="container">
             @if (TempData["Success"] != null)
             {
                 <div class="alert alert-success alert-dismissible fade show shadow-sm border-0" role="alert">
                     <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
                     <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                 </div>
             }
             @if (TempData["Error"] != null)
             {
                 <div class="alert alert-danger alert-dismissible fade show shadow-sm border-0" role="alert">
                     <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
                     <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                 </div>
             }
            @RenderBody()
        </div>
    </main>

    <footer class="footer border-top bg-white py-4 mt-auto">
        <div class="container text-center text-muted small">
            <p>&copy; 2026 Elevate Workforce Solutions - Developed by Code Art Web Technologies</p>
            <div class="mt-2">
                <a href="#" class="text-muted me-3 text-decoration-none">About</a>
                <a href="#" class="text-muted me-3 text-decoration-none">Accessibility</a>
                <a href="#" class="text-muted me-3 text-decoration-none">Privacy Policy</a>
                <a href="#" class="text-muted text-decoration-none">Help Center</a>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
