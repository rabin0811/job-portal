@model IEnumerable<JobPortal.Models.Application>
@{
    ViewData["Title"] = "Job Applicants";
    var jobTitle = Model.FirstOrDefault()?.Job?.Title ?? "Job";
    var jobId    = Model.FirstOrDefault()?.JobId ?? 0;
}

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
        <div>
            <h5 class="mb-0 fw-bold">Applicants for: @jobTitle</h5>
            <p class="text-muted small mb-0">@Model.Count() application(s) received</p>
        </div>
        <a asp-controller="Company" asp-action="Dashboard" class="btn btn-outline-secondary btn-sm rounded-pill px-3">← Dashboard</a>
    </div>

    @if (!Model.Any())
    {
        <div class="card-body text-center py-5">
            <i class="bi bi-people fs-1 text-muted mb-3 d-block"></i>
            <h6>No applicants yet</h6>
            <p class="text-muted small">Share the job link to attract candidates.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Applicant</th>
                        <th>Applied On</th>
                        <th>Cover Letter</th>
                        <th class="text-center">Status</th>
                        <th class="text-end pe-4">Update Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var app in Model)
                    {
                        var badgeClass = app.Status switch {
                            JobPortal.Models.ApplicationStatus.Accepted => "text-bg-success",
                            JobPortal.Models.ApplicationStatus.Rejected => "text-bg-danger",
                            JobPortal.Models.ApplicationStatus.Reviewed => "text-bg-info",
                            _ => "text-bg-secondary"
                        };
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold">@app.User?.Name</div>
                                <div class="text-muted small">@app.User?.Email</div>
                            </td>
                            <td class="text-muted small">@app.ApplicationDate.ToShortDateString()</td>
                            <td class="small text-muted" style="max-width:200px;">
                                @(string.IsNullOrEmpty(app.Message) ? "–" : app.Message.Length > 80 ? app.Message[..80] + "…" : app.Message)
                            </td>
                            <td class="text-center">
                                <span class="badge rounded-pill @badgeClass px-3 py-2">@app.Status</span>
                            </td>
                            <td class="text-end pe-4">
                                <form asp-action="UpdateStatus" method="post" class="d-inline-flex gap-1">
                                    <input type="hidden" name="id" value="@app.Id" />
                                    <input type="hidden" name="jobId" value="@app.JobId" />
                                    <button name="status" value="@((int)JobPortal.Models.ApplicationStatus.Accepted)"
                                            class="btn btn-sm btn-success rounded-pill px-2" title="Accept">✓</button>
                                    <button name="status" value="@((int)JobPortal.Models.ApplicationStatus.Reviewed)"
                                            class="btn btn-sm btn-info rounded-pill px-2 text-white" title="Mark Reviewed">👁</button>
                                    <button name="status" value="@((int)JobPortal.Models.ApplicationStatus.Rejected)"
                                            class="btn btn-sm btn-danger rounded-pill px-2" title="Reject">✕</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
