@model JobPortal.Models.Application
@{
    ViewData["Title"] = "Apply for Job";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-7 col-lg-6">
        <div class="card border-0 shadow-sm p-4">
            <h4 class="fw-bold mb-1">Submit Application</h4>
            <p class="text-muted small mb-4">Your profile will be shared with the employer</p>

            <form asp-action="Apply" method="post">
                <input type="hidden" asp-for="JobId" />

                <div class="mb-4">
                    <label class="form-label small fw-bold" asp-for="Message">Cover Letter / Notes</label>
                    <textarea asp-for="Message" class="form-control" rows="6"
                              placeholder="Tell the employer why you're a great fit for this role..."></textarea>
                    <div class="form-text text-muted small">Optional but recommended. Keep it concise and relevant.</div>
                </div>

                <div class="alert alert-light border small text-muted mb-4">
                    <i class="bi bi-info-circle me-2"></i>
                    By applying, your name and contact details will be shared with the employer.
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary rounded-pill px-5 fw-bold">Submit Application</button>
                    <a asp-controller="Job" asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
